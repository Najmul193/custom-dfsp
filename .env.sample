# External core / Mojaloop hub settings
CORE_HOST=192.168.1.100
CORE_PORT=3000
CORE_QUOTE_PORT=3002
CORE_ALS_PORT=4002
CORE_TRANSACTION_REQUESTS_PORT=4003

# DFSP identities and ports
SENDER_FSPID=senderfsp
RECEIVER_FSPID=receiverfsp
SENDER_PORT=8444
RECEIVER_PORT=8445

# Custom (Node) DFSPs
CUSTOM_SENDER_FSPID=custom-sender-fsp
CUSTOM_RECEIVER_FSPID=custom-receiver-fsp
CUSTOM_SENDER_PORT=3001
CUSTOM_RECEIVER_PORT=3002

# Optional: core admin API base URL (e.g. http://core-admin-host:port)
CORE_ADMIN_URL=

# Visualizer settings
VISUALIZER_PORT=3001
REFRESH_INTERVAL_SECONDS=5
